{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client", "google.maps", "node"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/lib/*": ["src/ui/lib/*"],
      "@/*": ["src/*"],
      "@chatwar/ui": ["src/ui/index.ts"],
      "@chatwar/ui/*": ["src/ui/*"],
      "@chatwar/shared": ["src/shared/index.ts"],
      "@chatwar/shared/*": ["src/shared/*"]
    }
  },
  "include": ["src"],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/test/**"
  ]
}
